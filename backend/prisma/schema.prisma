generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Workspace {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())

  customers  Customer[]
  orders     Order[]
  employees  AIEmployee[]
  knowledgeItems KnowledgeItem[]
   calls          Call[]
}

model Customer {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  phone       String
  city        String?
  aiSummary   String?
  aiInsights  String?
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id])
  orders    Order[]
}

model Order {
  id          String   @id @default(cuid())
  workspaceId String
  customerId  String
  product     String
  price       String?
  status      String   @default("Pending")
  callStatus String @default("Pending")
  aiSummary   String?
  notes       String?
  callbackAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id])
  customer  Customer  @relation(fields: [customerId], references: [id])
  events OrderEvent[]
  conversations Conversation[]
  calls Call[]
}

model AIEmployee {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  role        String
  language    String
  status      String   @default("Online")
  goal        String?
  script      String?
  rules String?
  tools String?
  conversations Conversation[]
  knowledgeItemIds String?
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id])
}
model OrderEvent {
  id          String   @id @default(cuid())
  orderId     String
  type        String
  title       String
  description String?
  createdAt   DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id])
}
model KnowledgeItem {
  id          String   @id @default(cuid())
  workspaceId String
  title       String
  content     String
  category    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id])
}
model Conversation {
  id           String   @id @default(cuid())
  orderId      String
  aiEmployeeId String?
  mode String @default("AI")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt

  order      Order             @relation(fields: [orderId], references: [id])
  aiEmployee AIEmployee?       @relation(fields: [aiEmployeeId], references: [id])
  messages   ConversationMessage[]
}

model ConversationMessage {
  id             String   @id @default(cuid())
  conversationId String
  sender         String
  content        String
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id])
}
model Product {
  id             String   @id @default(cuid())
  name           String
  price          String
  stock          String
  category       String
  description    String
  sku            String
  deliveryTime   String
  aiInstructions String
  status         String   @default("Active")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
model Call {
  id           String   @id @default(cuid())
  workspaceId  String
  orderId      String?
  customer     String
  phone        String
  product      String
  aiEmployee   String
  status       String   @default("Pending")
  duration     String   @default("00:00")
  transcript   String?
  summary      String?
  recordingUrl String?
  confidence   Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id])
  order     Order?     @relation(fields: [orderId], references: [id], onDelete: SetNull)
}